"""
Battle Royale Ranking Generator
"""


def generate_ranking(
    total_teams: int,
    first_place: int,
    mode: str
):
    """
    Generate placement points.

    Returns:
        [
            (1,35),
            (2,30),
            ...
        ]
    """

    rankings = []

    if mode == "winner":

        current = first_place

        for place in range(1, total_teams + 1):

            rankings.append(
                (
                    place,
                    max(current, 0)
                )
            )

            if place == 1:
                current -= 5

            elif place == 2:
                current -= 5

            elif place == 3:
                current -= 3

            elif place <= 5:
                current -= 2

            else:
                current -= 1

    else:

        if total_teams <= 1:

            rankings.append((1, first_place))

            return rankings

        step = first_place / (total_teams - 1)

        for place in range(total_teams):

            points = round(
                first_place - (step * place)
            )

            rankings.append(
                (
                    place + 1,
                    max(points, 0)
                )
            )

    return rankings


# ==========================================
# Preview
# ==========================================

def ranking_preview(rankings):

    text = "<pre>"

    text += "POS   PTS\n"

    text += "──────────\n"

    for place, points in rankings:

        text += f"{place:<4} {points}\n"

    text += "</pre>"

    return text
